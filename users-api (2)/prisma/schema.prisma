generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model UserEntity {
  id        Int           @id @default(autoincrement())
  email     String        @unique
  hashedPwd String
  fullname  String
  images    ImageEntity[]
}

model ImageEntity {
  id       Int        @id @default(autoincrement())
  height   Int
  width    Int
  data     String
  author   UserEntity @relation(fields: [authorId], references: [id])
  authorId Int
}
